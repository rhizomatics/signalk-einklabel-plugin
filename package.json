    "form-data": "^4.0.6",
    "luxon": "^3.7.2",
    "mathjs": "^15.2.0",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@signalk/server-api": "^2.28.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "^20.14.0",
    "@types/pngjs": "^6.0.5",
