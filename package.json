{
  "name": "@rhizomatics/signalk-einklabel-plugin",
  "version": "0.9.0-beta2",
  "description": "Display SignalK data on eInk Electronic Shelf Labels",
  "keywords": [
    "ble",
    "display",
    "eink",
    "esl",
    "instrument",
    "signalk",
    "signalk-category-hardware",
    "signalk-category-instruments",
    "signalk-node-server-plugin",
    "tides"
  ],
  "homepage": "https://github.com/rhizomatics/signalk-einklabel-plugin#readme",
  "bugs": {
